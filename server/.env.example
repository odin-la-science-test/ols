# Configuration du serveur email
EMAIL_SERVER_PORT=3001

# Configuration Gmail
# IMPORTANT: Utilisez un "App Password" (Mot de passe d'application)
# Pas votre mot de passe Gmail normal !
GMAIL_USER=votre.email@gmail.com
GMAIL_APP_PASSWORD=votre_mot_de_passe_application

# Environnement
NODE_ENV=development
