# Configuration du service d'email pour la vérification
# Copiez ce fichier en .env.local et remplissez vos clés API

# Provider d'email à utiliser
# Options: mock, sendgrid, aws-ses, mailgun, smtp, custom
EMAIL_PROVIDER=mock

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here

# AWS SES Configuration
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Mailgun Configuration
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_domain.mailgun.org

# SMTP Configuration (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email de l'expéditeur
FROM_EMAIL=noreply@odinlascience.com
FROM_NAME=Odin La Science

# Notes:
# - En mode 'mock', les emails sont affichés dans des notifications visuelles
# - Pour Gmail SMTP, utilisez un "App Password" au lieu de votre mot de passe normal
# - Pour AWS SES, assurez-vous que votre email est vérifié dans la console AWS
# - Pour SendGrid et Mailgun, créez un compte et obtenez une clé API
