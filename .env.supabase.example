# ============================================================================
# SUPABASE SCIENTIFIC DATABASE CONFIGURATION
# ============================================================================
# 
# Instructions:
# 1. Copiez ce fichier vers .env.local
# 2. Remplacez les valeurs par vos vraies clés Supabase
# 3. Ne commitez JAMAIS le fichier .env.local dans Git
#
# Pour obtenir vos clés:
# 1. Allez sur https://supabase.com
# 2. Ouvrez votre projet
# 3. Allez dans Settings > API
# 4. Copiez "Project URL" et "anon public" key
# ============================================================================

# URL de votre projet Supabase
# Format: https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Clé publique anonyme (anon public key)
# Cette clé est sûre pour être utilisée côté client
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ============================================================================
# NOTES DE SÉCURITÉ
# ============================================================================
#
# ⚠️ N'utilisez JAMAIS la clé service_role côté client !
# ⚠️ La clé anon public est sûre car elle respecte les politiques RLS
# ⚠️ Configurez correctement les politiques RLS dans Supabase Dashboard
#
# ============================================================================
